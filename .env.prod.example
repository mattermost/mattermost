# ==================================================
# Mattermost Production Environment Variables
# Copy file này thành .env trên VPS, điền giá trị thật
# KHÔNG commit file .env vào git!
# ==================================================

# --- Mattermost Version ---
MM_VERSION=latest

# --- Database ---
MM_DB_USER=mmuser
MM_DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MM_DB_NAME=mattermost

# --- Site URL (dùng IP nếu chưa có domain) ---
MM_SITE_URL=http://103.146.23.11:8065

# --- SMTP Email (tuỳ chọn) ---
MM_SMTP_AUTH=false
MM_SMTP_SERVER=localhost
MM_SMTP_PORT=25
MM_FEEDBACK_EMAIL=admin@yourdomain.com
MM_REPLY_EMAIL=admin@yourdomain.com
MM_SMTP_USER=
MM_SMTP_PASSWORD=
