# e2e-ai-agents: Ignore everything by default (auto-generated temporary files)
.e2e-ai-agents/

# EXCEPT: Track these critical files (needed for PR/CI decisions & recommendations)
!.e2e-ai-agents/gap.json              # Test gaps (uncovered flows)
!.e2e-ai-agents/impact.json           # Impact analysis (affected by code changes)
!.e2e-ai-agents/plan.json             # Test execution plan (recommendations)
!.e2e-ai-agents/traceability.json     # Test-to-file mappings (coverage data)

# ALSO TRACK: Documentation for MCP API quality control
!.e2e-ai-agents/spec-bridge-api.md    # Real Playwright API reference
!.e2e-ai-agents/MCP-API-GUIDE.md      # Team guide for validating generated tests

# Claude IDE cache (auto-generated, not needed - agents are in e2e-agents repo)
.claude/

playwright-report.json
