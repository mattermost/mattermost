exports[`components/emoji/components/AddEmoji should match snapshot 1`] = `
<div>
  <div
    class="backstage-content row"
  >
    <div
      class="backstage-header"
    >
      <h1>
        <a
          href="/undefined/emoji"
        >
          Custom Emoji
        </a>
        <span
          class="backstage-header__divider"
        >
          <i
            class="fa fa-angle-right"
            title="Breadcrumb Icon"
          />
        </span>
        Add
      </h1>
    </div>
    <div
      class="backstage-form"
    >
      <form
        class="form-horizontal"
      >
        <div
          class="form-group"
        >
          <label
            class="control-label col-sm-4"
            for="name"
          >
            Name
          </label>
          <div
            class="col-md-5 col-sm-8"
          >
            <input
              class="form-control"
              id="name"
              maxlength="64"
              type="text"
              value=""
            />
            <div
              class="form__help"
            >
              Specify an emoji name that's up to 64 characters. It can contain lowercase letters, numbers, and the symbols '-', '+' and '_'.
            </div>
          </div>
        </div>
        <div
          class="form-group"
        >
          <label
            class="control-label col-sm-4"
            for="image"
          >
            Image
          </label>
          <div
            class="col-md-5 col-sm-8"
          >
            <div>
              <div
                class="add-emoji__upload"
              >
                <button
                  class="btn btn-primary"
                >
                  Select
                </button>
                <input
                  accept=".jpeg,.jpg,.png,.gif"
                  id="select-emoji"
                  type="file"
                />
              </div>
              <div
                class="form__help"
              >
                Specify a .gif, .png, or .jpg file for your emoji. The file can be up to 512 KiB. The dimensions are resized automatically to 128 pixels by 128 pixels while maintaining the aspect ratio.
              </div>
            </div>
          </div>
        </div>
        <div
          class="backstage-form__footer"
        >
          <a
            class="btn btn-tertiary"
            href="/undefined/emoji"
          >
            Cancel
          </a>
          <button
            class="btn btn-primary"
            data-testid="save-button"
            type="submit"
          >
            Save
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
`;

