CURSOR_API_KEY=cursor_...

REPO_URL=https://github.com/your-org/your-repo
STARTING_REF=master

# --- CLI mode (npm start): point at one PR ---
# TARGET_PR_URL=https://github.com/your-org/your-repo/pull/42
# TARGET_PR_NUMBER=42

# --- Webhook mode (npm run webhook): runs on GitHub PR events ---
GITHUB_WEBHOOK_SECRET=
PORT=8788
WEBHOOK_PATH=/webhooks/github
# Comma-separated pull_request actions (default: synchronize,opened,reopened)
WEBHOOK_PR_ACTIONS=synchronize,opened,reopened
# Skip draft PRs (default on)
WEBHOOK_IGNORE_DRAFT=1

# Optional extra context for the planner (CLI or all webhook runs)
# FEATURE_DESCRIPTION=

MODEL_ID=composer-2.5
# TESTER_MODEL_ID=composer-2.5
# FIXER_MODEL_ID=composer-2.5

MAX_QA_ITERATIONS=3
POST_PR_COMMENT=1
